generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String        @id
  email          String        @unique
  mobileNumber   String?       @unique @map("mobile_number")
  name           String?
  avatarUrl      String?       @map("avatar_url")
  creditsBalance Int           @default(20) @map("credits_balance")
  isBanned       Boolean       @default(false) @map("is_banned")
  role           String        @default("USER") @map("role")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  createdBy      String?       @map("created_by")
  planName       String?       @default("None") @map("plan_name")
  planValidity   String?       @default("Lifetime") @map("plan_validity")
  planExpiresAt  DateTime?     @map("plan_expires_at")
  transactions   Transaction[]
  videos         Video[]

  @@map("users")
}

model Plan {
  id        String        @id @default(uuid())
  name      String        @unique
  price     Float
  credits   Int
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  features  PlanFeature[]

  @@map("plans")
}

model PlanFeature {
  id        String   @id @default(uuid())
  planId    String   @map("plan_id")
  text      String
  isEnabled Boolean  @default(true) @map("is_enabled")
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_features")
}

model Video {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  script       String
  avatarId     String      @map("avatar_id")
  voiceId      String      @map("voice_id")
  language     String
  videoUrl     String?     @map("video_url")
  thumbnailUrl String?     @map("thumbnail_url")
  status       VideoStatus @default(PENDING)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("videos")
}

model Transaction {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  amount            Float
  creditsGranted    Int      @map("credits_granted")
  razorpayOrderId   String   @unique @map("razorpay_order_id")
  razorpayPaymentId String?  @unique @map("razorpay_payment_id")
  status            String   @default("PENDING")
  createdAt         DateTime @default(now()) @map("created_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

enum VideoStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
