# Database
DATABASE_URL="postgresql://username:password@localhost:5432/scalio_ai_db?schema=public"

# Server Port
PORT=5000
FRONTEND_URL="http://localhost:3000"

# Firebase Admin SDK Configuration (Needed for token verification)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-firebase-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Payment Integration (Razorpay)
RAZORPAY_KEY_ID="rzp_test_xxxxxx"
RAZORPAY_KEY_SECRET="xxxxxx"

# HeyGen AI Video Generation Integration
HEYGEN_API_KEY="your_heygen_api_key_here"
